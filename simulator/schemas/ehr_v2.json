{
  "schema_version": "v2",
  "type": "object",
  "required": [
    "event_id",
    "patient_id",
    "ward",
    "heart_rate",
    "bp_systolic",
    "bp_diastolic",
    "spo2",
    "temperature_c",
    "timestamp"
  ],
  "properties": {
    "event_id":        { "type": "string" },
    "patient_id":      { "type": "string" },
    "ward":            { "type": "string", "enum": ["ICU", "GENERAL", "CARDIO", "NEURO"] },
    "heart_rate":      { "type": "number", "minimum": 0,  "maximum": 300 },
    "bp_systolic":     { "type": "number", "minimum": 0,  "maximum": 300 },
    "bp_diastolic":    { "type": "number", "minimum": 0,  "maximum": 200 },
    "spo2":            { "type": "number", "minimum": 0,  "maximum": 100 },
    "temperature_c":   { "type": "number", "minimum": 30, "maximum": 45  },
    "timestamp":       { "type": "string" },
    "respiratory_rate": { "type": "number", "minimum": 0, "maximum": 100 }
  }
}